  {
    "name": "Achanduin Castle",
    "country": "scotland",
    "region": "argyll-western-isles",
    "county": "Argyll and Bute",
    "lat": "56.49444444",
    "lng": "-5.56888889",
    "mapsLink": "https://www.google.com/maps/search/Achanduin%20Castle%20Argyll%20and%20Bute%20scotland",
    "image": "https://img.castlecore.uk/achanduin-castle.jpg",
