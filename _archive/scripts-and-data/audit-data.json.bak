  {
    "name": "Glasgow Cathedral",
    "country": "scotland",
    "region": "glasgow-stirling",
    "county": "Glasgow",
    "lat": "55.863",
    "lng": "-4.2346",
    "mapsLink": "https://www.google.com/maps/search/Glasgow%20Cathedral%20Glasgow%20scotland",
    "image": "https://img.castlecore.uk/glasgow-cathedral.jpg",
