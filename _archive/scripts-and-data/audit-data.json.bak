  {
    "name": "Eilean Donan Castle",
    "country": "scotland",
    "region": "highlands",
    "county": "Highland",
    "lat": "57.27402778",
    "lng": "-5.51611111",
    "mapsLink": "https://www.google.com/maps/search/Eilean%20Donan%20Castle%20Highland%20scotland",
    "image": "https://upload.wikimedia.org/wikipedia/commons/thumb/6/67/Eilean_Donan_Castle%2C_Scotland_-_Jan_2011.jpg/330px-Eilean_Donan_Castle%2C_Scotland_-_Jan_2011.jpg",
    "imgSource": "wikipedia",
    "gallery": [
      "https://img.castlecore.uk/eilean-donan-castle-2.jpg",
      "https://img.castlecore.uk/eilean-donan-castle-3.jpg",
      "https://img.castlecore.uk/eilean-donan-castle-4.jpg",
      "https://img.castlecore.uk/eilean-donan-castle-5.jpg",
      "https://img.castlecore.uk/eilean-donan-castle-interior-2.jpg",
