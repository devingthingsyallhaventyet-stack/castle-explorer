    "wiki": "https://en.wikipedia.org/wiki/Floors_Castle"
  },
  {
    "name": "Thirlestane Castle",
    "country": "scotland",
    "region": "borders",
    "county": "Scottish Borders",
    "lat": "55.7225",
    "lng": "-2.74361111",
    "mapsLink": "https://www.google.com/maps/search/Thirlestane%20Castle%20Scottish%20Borders%20scotland",
    "image": "https://upload.wikimedia.org/wikipedia/commons/thumb/b/b4/Thirlestane_Castle.jpg/330px-Thirlestane_Castle.jpg",
    "imgSource": "wikipedia",
