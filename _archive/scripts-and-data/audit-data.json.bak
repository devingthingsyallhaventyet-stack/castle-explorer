  {
    "name": "Kinneil House",
    "country": "scotland",
    "region": "glasgow-stirling",
    "county": "Falkirk",
    "lat": "56.0071",
    "lng": "-3.6342",
    "mapsLink": "https://www.google.com/maps/search/Kinneil%20House%20Falkirk%20scotland",
