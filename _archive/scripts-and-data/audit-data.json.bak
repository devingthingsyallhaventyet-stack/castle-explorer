  {
    "name": "Kilchurn Castle",
    "country": "scotland",
    "region": "argyll-western-isles",
    "county": "Argyll and Bute",
    "lat": "56.40361111",
    "lng": "-5.02888889",
    "mapsLink": "https://www.google.com/maps/search/Kilchurn%20Castle%20Argyll%20and%20Bute%20scotland",
    "image": "https://upload.wikimedia.org/wikipedia/commons/thumb/0/0e/Kilchurn_Castle_C15th%2C_Loch_Awe_-_geograph.org.uk_-_7618041.jpg/330px-Kilchurn_Castle_C15th%2C_Loch_Awe_-_geograph.org.uk_-_7618041.jpg",
    "imgSource": "wikipedia",
    "gallery": [
      "https://img.castlecore.uk/kilchurn-castle-2.jpg",
      "https://img.castlecore.uk/kilchurn-castle-3.jpg",
      "https://img.castlecore.uk/kilchurn-castle-4.jpg",
      "https://img.castlecore.uk/kilchurn-castle-5.jpg",
