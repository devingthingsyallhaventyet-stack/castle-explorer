ey.jpg","gallery":["https://img.castlecore.uk/iona-abbey-2.jpg","https://img.castlecore.uk/iona-abbey-3.jpg","https://img.castlecore.uk/iona-abbey-4.jpg","https://img.castlecore.uk/iona-abbey-5.jpg"],"tags":["well-preserved","photogenic","atmospheric","island","remote","celtic","medieval","coastal","guided-tours"]},{"name":"Sadell Castle","county":"Argyll and Bute","type":"castle","condition":"restored","era":"16th century","rating":4.1,"reviewCount":280,"access":"paid","description":"A restored tower house on the Kintyre coast, overlooking Sadell Bay towards Arran. Now a Landmark Trust holiday let in an idyllic Argyll setting.","image":"https://img.castlecore.uk/sadell-castle-3.jpg","gallery":["https://img.castlecore.uk/sadell-castle-2.jpg","https://img.castlecore.uk/sadell-castle-3.jpg","https://img.castlecore.uk/sadell-castle-4.jpg","https://img.castlecore.uk/sadell-castle-5.jpg"],"tags":["well-preserved","coastal","atmospheric","remote"]},{"name":"Achanduin Castle","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"13th century","rating":3.8,"reviewCount":120,"access":"free","description":"A 13th-century curtain wall castle on the Isle of Lismore, commanding views over Loch Linnhe. Once seat of the Bishops of Argyll in a stunningly beautiful island setting.","image":"https://img.castlecore.uk/achanduin-castle.jpg","gallery":["https://img.castlecore.uk/achanduin-castle-2.jpg","https://img.castlecore.uk/achanduin-castle-3.jpg","https://img.castlecore.uk/achanduin-castle-4.jpg","https://img.castlecore.uk/achanduin-castle-5.jpg"],"tags":["ruins-romantic","island","coastal","atmospheric","free-entry","remote","medieval"]},{"name":"Ardchattan Priory","county":"Argyll and Bute","type":"abbey","condition":"partial","era":"13th century","rating":3.9,"reviewCount":220,"access":"paid","description":"Romantic ruins of a Valliscaulian priory on the shore of Loch Etive, with fine medieval grave slabs. One of only three houses of this rare French monastic order in Scotland.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/ArdchattanPriory-pjt.jpg/500px-ArdchattanPriory-pjt.jpg","gallery":["https://img.castlecore.uk/ardchattan-priory-2.jpg","https://img.castlecore.uk/ardchattan-priory-3.jpg","https://img.castlecore.uk/ardchattan-priory-4.jpg","https://img.castlecore.uk/ardchattan-priory-5.jpg"],"tags":["ruins-romantic","coastal","atmospheric","gardens","medieval"]},{"name":"Kilmartin Church","county":"Argyll and Bute","type":"abbey","condition":"intact","era":"Medieval (in prehistoric landscape)","rating":4,"reviewCount":380,"access":"free","description":"A parish church at the heart of Kilmartin Glen — Scotland's richest prehistoric landscape — housing an outstanding collection of medieval carved grave slabs.","image":"https://img.castlecore.uk/kilmartin-church.jpg","gallery":["https://img.castlecore.uk/kilmartin-church-2.jpg","https://img.castlecore.uk/kilmartin-church-3.jpg","https://img.castlecore.uk/kilmartin-church-4.jpg","https://img.castlecore.uk/kilmartin-church-5.jpg"],"tags":["well-preserved","prehistoric","museum","atmospheric","celtic","free-entry"]},{"name":"Kilmun Church","county":"Argyll and Bute","type":"abbey","condition":"partial","era":"7th century onwards","rating":3.7,"reviewCount":180,"access":"free","description":"A historic church on Holy Loch in the Cowal Peninsula, with the mausoleum of the Dukes of Argyll. An atmospheric spot where Campbell chiefs rest among ancient yews.","image":"https://img.castlecore.uk/kilmun-church.jpg","gallery":["https://img.castlecore.uk/kilmun-church-2.jpg","https://img.castlecore.uk/kilmun-church-3.jpg","https://img.castlecore.uk/kilmun-church-4.jpg","https://img.castlecore.uk/kilmun-church-5.jpg"],"tags":["well-preserved","atmospheric","coastal","celtic","free-entry"]},{"name":"Ardencaple Castle","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"Medieval (demolished)","rating":3.2,"reviewCount":40,"access":"exterior-only","description":"Site of the former MacAulay clan seat near Helensburgh. Demolished in the 19th century, now within the grounds of a naval base. History erased by progress.","image":"https://img.castlecore.uk/ardencaple-castle.jpg","gallery":["https://img.castlecore.uk/ardencaple-castle-2.jpg","https://img.castlecore.uk/ardencaple-castle-3.jpg","https://img.castlecore.uk/ardencaple-castle-4.jpg","https://img.castlecore.uk/ardencaple-castle-5.jpg"],"tags":["free-entry"]},{"name":"Ardchonnel Castle","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"Medieval","rating":3.6,"reviewCount":80,"access":"free","description":"Another island fortress on Loch Awe — a Campbell stronghold on Inishail or a nearby island, part of the web of castles that controlled this vast Highland loch.","image":"https://img.castlecore.uk/ardchonnel-castle.jpg","gallery":["https://img.castlecore.uk/ardchonnel-castle-2.jpg","https://img.castlecore.uk/ardchonnel-castle-3.jpg","https://img.castlecore.uk/ardchonnel-castle-4.jpg","https://img.castlecore.uk/ardchonnel-castle-5.jpg"],"tags":["ruins-romantic","island","remote","free-entry"]},{"name":"Castle Loch Heylipol","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"Medieval","rating":3.2,"reviewCount":30,"access":"free","description":"Traces of a crannog castle on the Isle of Tiree, one of the most wind-swept and sun-blessed islands in Scotland.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/DSCN6522_Island_House%2C_Tiree.jpg/500px-DSCN6522_Island_House%2C_Tiree.jpg","gallery":["https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/DSCN6522_Island_House%2C_Tiree.jpg/500px-DSCN6522_Island_House%2C_Tiree.jpg","https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/DSCN6523_Island_House%2C_Tiree.jpg/500px-DSCN6523_Island_House%2C_Tiree.jpg","https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/DSCN6528_Island_House%2C_Tiree.jpg/500px-DSCN6528_Island_House%2C_Tiree.jpg","https://upload.wikimedia.org/wikipedia/commons/thumb/1/1f/DSCN6531_Island_House%2C_Tiree.jpg/500px-DSCN6531_Island_House%2C_Tiree.jpg"],"tags":["ruins-romantic","island","remote","free-entry"]},{"name":"Crarae Garden Castle","county":"Argyll and Bute","type":"castle","condition":"intact","era":"20th century","rating":4.3,"reviewCount":880,"access":"paid","description":"A woodland garden of extraordinary beauty on Loch Fyne, often called 'the Himalayan Gorge of Scotland'. Rare plants in a dramatic glen setting.","image":"https://img.castlecore.uk/crarae-garden-castle.jpg","gallery":["https://img.castlecore.uk/crarae-garden-castle-2.jpg","https://img.castlecore.uk/crarae-garden-castle-3.jpg","https://img.castlecore.uk/crarae-garden-castle-4.jpg","https://img.castlecore.uk/crarae-garden-castle-5.jpg"],"tags":["well-preserved","gardens","woodland","atmospheric"]},{"name":"Dunderave Castle","county":"Argyll and Bute","type":"castle","condition":"restored","era":"16th century","rating":3.8,"reviewCount":120,"access":"exterior-only","description":"A restored tower house on the shores of Loch Fyne, beautifully sited with views across the loch. The MacNaughton clan seat, rescued from near-total ruin.","image":"https://img.castlecore.uk/wiki-dunderave-castle.jpg","tags":["well-preserved","coastal","atmospheric","medieval"]},{"name":"Cardross Manor","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"14th century","rating":3.3,"reviewCount":40,"access":"free","description":"Site where Robert the Bruce spent his final years and died in 1329. Almost nothing survives, but the historical significance is immense.","image":"https://img.castlecore.uk/cardross-manor.jpg","gallery":["https://img.castlecore.uk/cardross-manor-2.jpg","https://img.castlecore.uk/cardross-manor-3.jpg","https://img.castlecore.uk/cardross-manor-4.jpg","https://img.castlecore.uk/cardross-manor-5.jpg"],"tags":["free-entry","medieval"]},{"name":"Kilberry Sculptured Stones","county":"Argyll and Bute","type":"abbey","condition":"intact","era":"14th-16th century","rating":3.7,"reviewCount":80,"access":"free","description":"A collection of medieval West Highland carved stones near Kilberry in Argyll. Masterpieces of Gaelic memorial art.","image":"https://img.castlecore.uk/kilberry-sculptured-stones.jpg","gallery":["https://img.castlecore.uk/kilberry-sculptured-stones-2.jpg","https://img.castlecore.uk/kilberry-sculptured-stones-3.jpg","https://img.castlecore.uk/kilberry-sculptured-stones-4.jpg","https://img.castlecore.uk/kilberry-sculptured-stones-5.jpg"],"tags":["well-preserved","medieval","celtic","free-entry","remote"]},{"name":"Dunadd Fort","county":"Argyll and Bute","type":"castle","condition":"ruin","era":"Iron Age / Early Medieval","rating":4.4,"reviewCount":1800,"access":"free","description":"The ancient capital of Dál Riata — climb this rocky outcrop in Kilmartin Glen and place your foot in the same carved footprint where Dark Age kings were crowned in the birthplace of Scotland.","image":"https://img.castlecore.uk/dunadd-fort.jpg","gallery":["https://img.castlecore.uk/dunadd-fort-2.jpg","https://img.castlecore.uk/dunadd-fort-3.jpg","https://img.castlecore.uk/dunadd-fort-4.jpg","https://img.castlecore.uk/dunadd-fort-5.jpg"],"tags":["atmospheric","prehistoric","hilltop","free-entry","remote","photogenic","celtic"]},{"name":"Ballinaby Standing Stones","county":"Argyll and Bute","type":"castle","condition":"intact","era":"Bronze Age","rating":3.6,"reviewCount":60,"access":"free","description":"Bronze Age standing stones on the west coast of Islay, part of the island's extraordinary prehistoric landscape.","image":"https://img.castlecore.uk/ballinaby-standing-stones.jpg","gallery":["https://img.castlecore.uk/ballinaby-standing-stones-2.jpg","https://img.castlecore.uk/ballinaby-standing-stones-3.jpg","https://img.castlecore.uk/ballinaby-standing-stones-4.jpg","https://img.castlecore.uk/ballinaby-standing-stones-5.jpg"],"tags":["prehistoric","free-entry","remote","island","atmospheric"]},{"name":"Keills Chapel","county":"Argyll and Bute","type":"abbey","condition":"ruin","era":"8th century / Medieval","rating":4.1,"reviewCount":220,"access":"free","description":"A tiny medieval chapel on the remote Knapdale coast housing a superb 8th-century cross. An atmospheric gem at the end of a single-track road.","image":"https://img.castlecore.uk/keills-chapel.jpg","gallery":["https://img.castlecore.uk/keills-chapel-2.jpg","https://img.castlecore.uk/keills-chapel-3.jpg","https://img.castlecore.uk/keills-chapel-4.jpg","https://img.castlecore.uk/keills-chapel-5.jpg"],"tags":["well-preserved","celtic","coastal","remote","atmospheric","free-entry","medieval"]},{"name":"Kildalton Cross","county":"Argyll and Bute","type":"abbey","condition":"intact","era":"8th century","rating":4.5,"reviewCount":680,"access":"free","description":"The finest intact high cross in Scotland â€” an 8th-century masterpiece of Celtic art on Islay. Breathtaking craftsmanship.","image":"https://img.castlecore.uk/kildalton-cross.jpg","gallery":["https://img.castlecore.uk/kildalton-cross-2.jpg","https://img.castlecore.uk/kildalton-cross-3.jpg","https://img.castlecore.uk/kildalton-cross-4.jpg","https://img.castlecore.uk/kildalton-cross-5.jpg"],"tags":["well-preserved","celtic","atmospheric","free-entry","island","remote"]},{"name":"Campbeltown Cross","county":"Argyll and Bute","type":"abbey","condition":"intact","era":"15th century","rating":3.5,"reviewCount":80,"access":"free","description":"A fine 15th-century medieval market cross in Kintyre, carved with Celtic interlace and a crucifixion scene.","image":"https://img.castlecore.uk/campbeltown-cross.jpg","gallery":["https://img.castlecore.uk/campbeltown-cross-2.jpg","https://img.castlecore.uk/campbeltown-cross-3.jpg","https://img.castlecore.uk/campbeltown-cross-4.jpg","https://img.castlecore.uk/campbeltown-cross-5.jpg"],"tags":["well-preserved","medieval","celtic","free-entry"]},{"name":"St Blane's Church","county":"Argyll and Bute","type":"abbey","condition":"ruin","era":"6th century onwards","rating":4.2,"reviewCount":380,"access":"free","description":"Beautifully sited early medieval monastery ruin on the Isle of Bute. Celtic Christian ruins in an idyllic island setting.","image":"https://img.castlecore.uk/st-blane-s-church.jpg","gallery":["https://img.castlecore.uk/st-blane-s-church-2.jpg","https://img.castlecore.uk/st-blane-s-church-3.jpg","https://img.castlecore.uk/st-blane-s-church-4.jpg","https://img.castlecore.uk/st-blane-s-church-5.jpg"],"tags":["ruins-romantic","celtic","atmospheric","free-entry","island","remote"]},{"name":"Innischonain Priory","county":"Argyll and Bute","type":"abbey","condition":"ruin","era":"13th century","rating":3.3,"reviewCount":30,"access":"free","description":"Ruins of an Augustinian priory on an island in Loch Awe. Monastic solitude on one of Argyll's most beautiful lochs.","image":"https://img.castlecore.uk/innischonain-priory.jpg","gallery":["https://img.castlecore.uk/innischonain-priory-2.jpg","https://img.castlecore.uk/innischonain-priory-3.jpg","https://img.castlecore.uk/innischonain-priory-4.jpg","https://img.castlecore.uk/innischonain-priory-5.jpg"],"tags":["ruins-romantic","island","remote","atmospheric","free-entry","celtic"]}]