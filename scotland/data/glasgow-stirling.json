[{"name":"Stirling Castle","county":"Stirling","type":"castle","condition":"intact","era":"12th century","rating":4.6,"reviewCount":15000,"access":"paid","description":"One of Scotland's most historically important castles, Stirling was the prize at the Battle of Bannockburn in 1314 and the site near William Wallace's triumph at Stirling Bridge in 1297. Later the childhood home of Mary, Queen of Scots, its Renaissance palace is the finest of its kind in Britain.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Scotland-2016-Aerial-Stirling-Stirling_Castle.jpg/500px-Scotland-2016-Aerial-Stirling-Stirling_Castle.jpg","gallery":["https://img.castlecore.uk/stirling-castle-2.jpg","https://img.castlecore.uk/stirling-castle-3.jpg","https://img.castlecore.uk/stirling-castle-4.jpg","https://img.castlecore.uk/stirling-castle-5.jpg","https://img.castlecore.uk/stirling-castle-interior-2.jpg","https://img.castlecore.uk/stirling-castle-interior-3.jpg","https://img.castlecore.uk/stirling-castle-interior-4.jpg","https://img.castlecore.uk/stirling-castle-interior-5.jpg"],"tags":["well-preserved","kid-friendly","photogenic"]},{"name":"Doune Castle","county":"Stirling","type":"castle","condition":"partial ruin","era":"14th century","rating":4.4,"reviewCount":3450,"access":"paid","description":"A magnificent late 14th-century courtyard castle built for the Regent Albany. Doune served as a filming location for Monty Python, Game of Thrones, and Outlander.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/eb/Scotland-2016-Aerial-Doune_Castle_%28and_Castle_keeper%27s_cottage%29.jpg/500px-Scotland-2016-Aerial-Doune_Castle_%28and_Castle_keeper%27s_cottage%29.jpg","gallery":["https://img.castlecore.uk/doune-castle-2.jpg","https://img.castlecore.uk/doune-castle-3.jpg","https://img.castlecore.uk/doune-castle-4.jpg","https://img.castlecore.uk/doune-castle-5.jpg","https://img.castlecore.uk/doune-castle-main-2.jpg","https://img.castlecore.uk/doune-castle-main-3.jpg","https://img.castlecore.uk/doune-castle-main-4.jpg","https://img.castlecore.uk/doune-castle-main-5.jpg"],"tags":["well-preserved","filming-location","photogenic"]},{"name":"Dunblane Cathedral","county":"Stirling","type":"abbey","condition":"intact","era":"13th century","rating":4.3,"reviewCount":1890,"access":"free","description":"A magnificent Gothic cathedral restored from ruin in the 19th century. The lower courses of the tower date from the 11th century and the choir stalls are medieval.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Moyry_Castle_1.jpg/500px-Moyry_Castle_1.jpg","gallery":["https://img.castlecore.uk/dunblane-cathedral-2.jpg","https://img.castlecore.uk/dunblane-cathedral-3.jpg","https://img.castlecore.uk/dunblane-cathedral-4.jpg","https://img.castlecore.uk/dunblane-cathedral-5.jpg"],"tags":["well-preserved","hidden-gem","free"]},{"name":"Inchmahome Priory","county":"Stirling","type":"abbey","condition":"ruin","era":"13th century","rating":4.3,"reviewCount":1560,"access":"paid","description":"A beautiful Augustinian priory on an island in the Lake of Menteith. The infant Mary, Queen of Scots was hidden here for safety in 1547 before being sent to France.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/67/Inchmahome_Priory_-_2_-_06052008.jpg/500px-Inchmahome_Priory_-_2_-_06052008.jpg","gallery":["https://img.castlecore.uk/inchmahome-priory-2.jpg","https://img.castlecore.uk/inchmahome-priory-3.jpg","https://img.castlecore.uk/inchmahome-priory-4.jpg","https://img.castlecore.uk/inchmahome-priory-5.jpg"],"tags":["romantic-ruin","photogenic","hidden-gem"]},{"name":"Craignethan Castle","county":"South Lanarkshire","type":"castle","condition":"ruin","era":"16th century","rating":4,"reviewCount":890,"access":"paid","description":"A sophisticated Renaissance castle with a unique caponier (underground artillery chamber) — the only one of its kind in Britain. Possibly the inspiration for Sir Walter Scott's Tillietudlem.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2d/Craignethan_Castle.jpg/500px-Craignethan_Castle.jpg","gallery":["https://img.castlecore.uk/craignethan-castle-2.jpg","https://img.castlecore.uk/craignethan-castle-3.jpg","https://img.castlecore.uk/craignethan-castle-4.jpg","https://img.castlecore.uk/craignethan-castle-5.jpg","https://img.castlecore.uk/craignethan-castle-tower-2.jpg","https://img.castlecore.uk/craignethan-castle-tower-3.jpg","https://img.castlecore.uk/craignethan-castle-tower-4.jpg","https://img.castlecore.uk/craignethan-castle-tower-5.jpg"],"tags":["dramatic-ruin","hidden-gem"]},{"name":"Bothwell Castle","county":"South Lanarkshire","type":"castle","condition":"ruin","era":"13th century","rating":4.3,"reviewCount":1890,"access":"paid","description":"The largest and finest 13th-century stone castle in Scotland, Bothwell changed hands five times during the Wars of Independence. Its massive circular donjon is French in inspiration.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Bothwell_Castle_20080505_-_south-east_tower.jpg/500px-Bothwell_Castle_20080505_-_south-east_tower.jpg","gallery":["https://img.castlecore.uk/bothwell-castle-2.jpg","https://img.castlecore.uk/bothwell-castle-3.jpg","https://img.castlecore.uk/bothwell-castle-4.jpg","https://img.castlecore.uk/bothwell-castle-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"Newark Castle","county":"Inverclyde","type":"castle","condition":"intact","era":"15th century","rating":4.1,"reviewCount":1120,"access":"paid","description":"A remarkably well-preserved castle on the Clyde at Port Glasgow. The Maxwell family's tower house and later Renaissance mansion overlook the river where ships once launched.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6c/Dean_Castle%2C_East_Ayrshire_%28cropped%29.jpg/500px-Dean_Castle%2C_East_Ayrshire_%28cropped%29.jpg","gallery":["https://img.castlecore.uk/newark-castle-2.jpg","https://img.castlecore.uk/newark-castle-3.jpg","https://img.castlecore.uk/newark-castle-4.jpg","https://img.castlecore.uk/newark-castle-5.jpg","https://img.castlecore.uk/newark-castle-main-2.jpg","https://img.castlecore.uk/newark-castle-main-3.jpg","https://img.castlecore.uk/newark-castle-main-4.jpg","https://img.castlecore.uk/newark-castle-main-5.jpg"],"tags":["well-preserved","hidden-gem"]},{"name":"Dumbarton Castle","county":"West Dunbartonshire","type":"castle","condition":"partial ruin","era":"Iron Age-present","rating":4.2,"reviewCount":1400,"access":"paid","description":"Scotland's oldest recorded stronghold — a volcanic rock fortress on the Clyde with an unbroken history stretching back to the Iron Age. William Wallace was held here in 1305 before being transported to London for execution.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/Scotland_Dumbarton_Castle_bordercropped.jpg/500px-Scotland_Dumbarton_Castle_bordercropped.jpg","gallery":["https://img.castlecore.uk/dumbarton-castle-2.jpg","https://img.castlecore.uk/dumbarton-castle-3.jpg","https://img.castlecore.uk/dumbarton-castle-4.jpg","https://img.castlecore.uk/dumbarton-castle-5.jpg","https://img.castlecore.uk/dumbarton-castle-main-2.jpg","https://img.castlecore.uk/dumbarton-castle-main-3.jpg","https://img.castlecore.uk/dumbarton-castle-main-4.jpg","https://img.castlecore.uk/dumbarton-castle-main-5.jpg"],"tags":["dramatic-ruin","photogenic","hilltop","coastal","medieval","prehistoric"]},{"name":"Cadzow Castle","county":"South Lanarkshire","type":"castle","condition":"ruin","era":"12th-16th century","rating":3.8,"reviewCount":350,"access":"free","description":"Perched above a dramatic gorge in ancient royal parkland, Cadzow's crumbling walls overlook the Avon Water where white cattle still roam. A medieval hunting lodge for Scottish kings, now a moody ruin in one of Scotland's most atmospheric country parks.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/79/CadzowCastle01.JPG/500px-CadzowCastle01.JPG","gallery":["https://img.castlecore.uk/cadzow-castle-2.jpg","https://img.castlecore.uk/cadzow-castle-3.jpg","https://img.castlecore.uk/cadzow-castle-4.jpg","https://img.castlecore.uk/cadzow-castle-5.jpg","https://img.castlecore.uk/cadzow-castle-main-2.jpg","https://img.castlecore.uk/cadzow-castle-main-3.jpg","https://img.castlecore.uk/cadzow-castle-main-4.jpg","https://img.castlecore.uk/cadzow-castle-main-5.jpg"],"tags":["ruins-romantic","woodland","riverside","atmospheric","free-entry","medieval","dog-friendly"]},{"name":"Crookston Castle","county":"Glasgow","type":"castle","condition":"ruin","era":"12th-15th century","rating":3.9,"reviewCount":420,"access":"free","description":"Glasgow's only surviving medieval castle — built by the Stewarts of Darnley on a hilltop with 12th-century earthworks, where Mary Queen of Scots may have spent her honeymoon.","image":"https://img.castlecore.uk/crookston-castle.jpg","gallery":["https://img.castlecore.uk/crookston-castle-2.jpg","https://img.castlecore.uk/crookston-castle-3.jpg","https://img.castlecore.uk/crookston-castle-4.jpg","https://img.castlecore.uk/crookston-castle-5.jpg","https://img.castlecore.uk/crookston-castle-main-2.jpg","https://img.castlecore.uk/crookston-castle-main-3.jpg","https://img.castlecore.uk/crookston-castle-main-4.jpg","https://img.castlecore.uk/crookston-castle-main-5.jpg"],"tags":["ruins-romantic","hilltop","medieval","atmospheric","free-entry"]},{"name":"Mugdock Castle","county":"East Dunbartonshire","type":"castle","condition":"ruin","era":"14th century","rating":3.7,"reviewCount":450,"access":"free","description":"A brooding 14th-century Graham stronghold wrapped in ancient woodland, its solitary tower rising from the mossy ruins of a clan empire. Atmospheric walks through Mugdock Country Park lead to this hauntingly beautiful shell — dark heritage meets wild Scottish countryside.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8b/Mugdock_Side1.jpg/500px-Mugdock_Side1.jpg","gallery":["https://img.castlecore.uk/mugdock-castle-2.jpg","https://img.castlecore.uk/mugdock-castle-3.jpg","https://img.castlecore.uk/mugdock-castle-4.jpg","https://img.castlecore.uk/mugdock-castle-5.jpg","https://img.castlecore.uk/mugdock-castle-main-2.jpg","https://img.castlecore.uk/mugdock-castle-main-3.jpg","https://img.castlecore.uk/mugdock-castle-main-4.jpg","https://img.castlecore.uk/mugdock-castle-main-5.jpg"],"tags":["ruins-romantic","woodland","free-entry","atmospheric","dark-brooding","dog-friendly","hidden-gem"]},{"name":"Finlaystone Castle","county":"Inverclyde","type":"castle","condition":"intact","era":"14th century onwards","rating":3.4,"reviewCount":22,"access":"paid","description":"A country house estate on the Clyde near Langbank, home to the Cunninghame-Graham family. Woodlands, gardens, and connections to both John Knox and Robert Burns.","image":"https://img.castlecore.uk/finlaystone-castle.jpg","tags":["well-preserved","gardens","kid-friendly","woodland","dog-friendly","events-venue"]},{"name":"Balloch Castle","county":"West Dunbartonshire","type":"castle","condition":"intact","era":"19th century","rating":3.8,"reviewCount":620,"access":"free","description":"A Gothic Revival castle set in a country park on the southern shore of Loch Lomond. The gateway to the Highlands, with stunning lochside grounds.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/02/BallochCastleScotland.jpg/500px-BallochCastleScotland.jpg","gallery":["https://img.castlecore.uk/balloch-castle-2.jpg","https://img.castlecore.uk/balloch-castle-3.jpg","https://img.castlecore.uk/balloch-castle-4.jpg","https://img.castlecore.uk/balloch-castle-5.jpg"],"tags":["well-preserved","gardens","kid-friendly","dog-friendly","woodland","free-entry","gothic"]},{"name":"Cambuskenneth Abbey","county":"Stirling","type":"abbey","condition":"ruin","era":"12th century","rating":4,"reviewCount":420,"access":"free","description":"A hauntingly beautiful ruined abbey near Stirling, with a soaring detached bell tower. The burial place of James III and his queen — Scotland's lost royal mausoleum.","image":"https://img.castlecore.uk/cambuskenneth-abbey.jpg","gallery":["https://img.castlecore.uk/cambuskenneth-abbey-2.jpg","https://img.castlecore.uk/cambuskenneth-abbey-3.jpg","https://img.castlecore.uk/cambuskenneth-abbey-4.jpg","https://img.castlecore.uk/cambuskenneth-abbey-5.jpg"],"tags":["ruins-romantic","medieval","atmospheric","free-entry"]},{"name":"Paisley Abbey","county":"Renfrewshire","type":"abbey","condition":"restored","era":"12th century","rating":4.4,"reviewCount":2200,"access":"free","description":"A Cluniac monastery with royal bones beneath its floors — burial place of Scotland's High Stewards and the mother of the royal Stewart dynasty.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/Paisley_Abbey_from_North_West_-_Leaning_western_gable_-_125mp.jpg/500px-Paisley_Abbey_from_North_West_-_Leaning_western_gable_-_125mp.jpg","gallery":["https://img.castlecore.uk/paisley-abbey-2.jpg","https://img.castlecore.uk/paisley-abbey-3.jpg","https://img.castlecore.uk/paisley-abbey-4.jpg","https://img.castlecore.uk/paisley-abbey-5.jpg"],"tags":["well-preserved","atmospheric","medieval","free-entry"]},{"name":"Glasgow Cathedral","county":"Glasgow","type":"abbey","condition":"intact","era":"13th-15th century","rating":4.7,"reviewCount":8200,"access":"free","description":"Scotland's finest medieval cathedral — miraculously unscathed by the Reformation, its atmospheric lower church and forest of stone pillars guard the tomb of St Mungo.","image":"https://img.castlecore.uk/glasgow-cathedral.jpg","gallery":["https://img.castlecore.uk/glasgow-cathedral-2.jpg","https://img.castlecore.uk/glasgow-cathedral-3.jpg","https://img.castlecore.uk/glasgow-cathedral-4.jpg","https://img.castlecore.uk/glasgow-cathedral-5.jpg"],"tags":["well-preserved","photogenic","gothic","medieval","atmospheric","dark-brooding","free-entry"]},{"name":"Tower of Hallbar","county":"South Lanarkshire","type":"castle","condition":"restored","era":"16th century","rating":3.7,"reviewCount":120,"access":"paid","description":"A restored 16th-century tower house near Crossford in Lanarkshire, now a Landmark Trust holiday let. A compact fortress brought beautifully back to life.","image":"https://img.castlecore.uk/tower-of-hallbar.jpg","gallery":["https://img.castlecore.uk/tower-of-hallbar-2.jpg","https://img.castlecore.uk/tower-of-hallbar-3.jpg","https://img.castlecore.uk/tower-of-hallbar-4.jpg","https://img.castlecore.uk/tower-of-hallbar-5.jpg"],"tags":["well-preserved","medieval","atmospheric"]},{"name":"Castle Levan","county":"Inverclyde","type":"castle","condition":"ruin","era":"15th century","rating":3.4,"reviewCount":50,"access":"free","description":"A ruined tower house near Gourock, overlooking the Firth of Clyde. Once a Morton stronghold, now a crumbling relic in the Inverclyde landscape.","image":"https://img.castlecore.uk/castle-levan.jpg","gallery":["https://img.castlecore.uk/castle-levan-2.jpg","https://img.castlecore.uk/castle-levan-3.jpg","https://img.castlecore.uk/castle-levan-4.jpg","https://img.castlecore.uk/castle-levan-5.jpg"],"tags":["ruins-romantic","coastal","free-entry"]},{"name":"Lennox Castle","county":"East Dunbartonshire","type":"castle","condition":"ruin","era":"19th century","rating":3.3,"reviewCount":80,"access":"exterior-only","description":"A vast ruined Victorian Gothic castle near Lennoxtown, once a psychiatric hospital. An enormous and eerie shell in the Campsie Fells.","image":"https://img.castlecore.uk/lennox-castle.jpg","gallery":["https://img.castlecore.uk/lennox-castle-2.jpg","https://img.castlecore.uk/lennox-castle-3.jpg","https://img.castlecore.uk/lennox-castle-4.jpg","https://img.castlecore.uk/lennox-castle-5.jpg"],"tags":["ruins-romantic","gothic","dark-brooding","atmospheric","victorian"]},{"name":"Kilmacolm Castle","county":"Renfrewshire","type":"castle","condition":"ruin",