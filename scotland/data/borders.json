[{"name":"Hermitage Castle","county":"Scottish Borders","type":"castle","condition":"partial ruin","era":"13th century","rating":4.5,"reviewCount":1800,"access":"paid","description":"The most sinister-looking castle in Scotland, Hermitage broods over the bleak Borders landscape. Its dark history includes murder, starvation, and a visit from Mary, Queen of Scots.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e9/Hermitage_Castle_06.jpg/500px-Hermitage_Castle_06.jpg","gallery":["https://img.castlecore.uk/hermitage-castle-2.jpg","https://img.castlecore.uk/hermitage-castle-3.jpg","https://img.castlecore.uk/hermitage-castle-4.jpg","https://img.castlecore.uk/hermitage-castle-5.jpg","https://img.castlecore.uk/hermitage-castle-interior-2.jpg","https://img.castlecore.uk/hermitage-castle-interior-3.jpg","https://img.castlecore.uk/hermitage-castle-interior-4.jpg","https://img.castlecore.uk/hermitage-castle-interior-5.jpg"],"tags":["dramatic-ruin","haunted","hidden-gem","photogenic"]},{"name":"Melrose Abbey","county":"Scottish Borders","type":"abbey","condition":"ruin","era":"12th century","rating":4.7,"reviewCount":5800,"access":"paid","description":"The finest ruined abbey in Scotland, Melrose was founded by Cistercian monks in 1136. Robert the Bruce's heart is believed to be buried here. Its Gothic stonework is exquisite.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d7/Thomas_Girtin_006.JPG/500px-Thomas_Girtin_006.JPG","gallery":["https://img.castlecore.uk/melrose-abbey-2.jpg","https://img.castlecore.uk/melrose-abbey-3.jpg","https://img.castlecore.uk/melrose-abbey-4.jpg","https://img.castlecore.uk/melrose-abbey-5.jpg","https://img.castlecore.uk/melrose-abbey-ruins-2.jpg","https://img.castlecore.uk/melrose-abbey-ruins-3.jpg","https://img.castlecore.uk/melrose-abbey-ruins-4.jpg","https://img.castlecore.uk/melrose-abbey-ruins-5.jpg"],"tags":["dramatic-ruin","photogenic"]},{"name":"Jedburgh Abbey","county":"Scottish Borders","type":"abbey","condition":"ruin","era":"12th century","rating":4.3,"reviewCount":2670,"access":"paid","description":"One of the great Border Abbeys founded by David I, Jedburgh's Romanesque and Gothic arches still soar to impressive heights. It suffered greatly from English raids.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/Dryburgh_Abbey%2C_2004.jpg/500px-Dryburgh_Abbey%2C_2004.jpg","gallery":["https://img.castlecore.uk/jedburgh-abbey-2.jpg","https://img.castlecore.uk/jedburgh-abbey-3.jpg","https://img.castlecore.uk/jedburgh-abbey-4.jpg","https://img.castlecore.uk/jedburgh-abbey-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"Dryburgh Abbey","county":"Scottish Borders","type":"abbey","condition":"ruin","era":"12th century","rating":4.5,"reviewCount":2800,"access":"paid","description":"The most beautifully situated of the Border Abbeys, in a loop of the River Tweed. Sir Walter Scott and Field Marshal Haig are buried in its atmospheric ruins.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/Dryburgh_Abbey%2C_2004.jpg/500px-Dryburgh_Abbey%2C_2004.jpg","gallery":["https://img.castlecore.uk/dryburgh-abbey-2.jpg","https://img.castlecore.uk/dryburgh-abbey-3.jpg","https://img.castlecore.uk/dryburgh-abbey-4.jpg","https://img.castlecore.uk/dryburgh-abbey-5.jpg","https://img.castlecore.uk/dryburgh-abbey-ruins-2.jpg","https://img.castlecore.uk/dryburgh-abbey-ruins-3.jpg","https://img.castlecore.uk/dryburgh-abbey-ruins-4.jpg","https://img.castlecore.uk/dryburgh-abbey-ruins-5.jpg"],"tags":["romantic-ruin","photogenic","hidden-gem"]},{"name":"Kelso Abbey","county":"Scottish Borders","type":"abbey","condition":"ruin","era":"12th century","rating":4.3,"reviewCount":1600,"access":"free","description":"Once the largest and richest of the Border Abbeys, Kelso was founded by David I in 1128. Only the massive Romanesque west end survives of what was a magnificent church.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f5/Kelso_Abbey1.jpg/500px-Kelso_Abbey1.jpg","gallery":["https://img.castlecore.uk/kelso-abbey-2.jpg","https://img.castlecore.uk/kelso-abbey-3.jpg","https://img.castlecore.uk/kelso-abbey-4.jpg","https://img.castlecore.uk/kelso-abbey-5.jpg","https://img.castlecore.uk/kelso-abbey-ruins-2.jpg","https://img.castlecore.uk/kelso-abbey-ruins-3.jpg","https://img.castlecore.uk/kelso-abbey-ruins-4.jpg","https://img.castlecore.uk/kelso-abbey-ruins-5.jpg"],"tags":["dramatic-ruin","hidden-gem","free"]},{"name":"Neidpath Castle","county":"Scottish Borders","type":"castle","condition":"partial ruin","era":"14th century","rating":4,"reviewCount":890,"access":"paid","description":"A dramatic tower house perched above the River Tweed near Peebles. Its L-plan design and rock-cut cellars show the ingenuity of medieval Scottish castle builders.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0e/Neidpath_Castle_2014_1.jpg/500px-Neidpath_Castle_2014_1.jpg","gallery":["https://img.castlecore.uk/neidpath-castle-2.jpg","https://img.castlecore.uk/neidpath-castle-3.jpg","https://img.castlecore.uk/neidpath-castle-4.jpg","https://img.castlecore.uk/neidpath-castle-5.jpg"],"tags":["dramatic-ruin","hidden-gem"]},{"name":"Smailholm Tower","county":"Scottish Borders","type":"tower house","condition":"partial ruin","era":"15th century","rating":4.2,"reviewCount":1120,"access":"paid","description":"A Border peel tower perched on a rocky knoll with panoramic views. Young Walter Scott spent childhood days here, and it inspired his love of Border ballads and legends.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/69/SmailholmLochan.jpg/500px-SmailholmLochan.jpg","gallery":["https://img.castlecore.uk/smailholm-tower-2.jpg","https://img.castlecore.uk/smailholm-tower-3.jpg","https://img.castlecore.uk/smailholm-tower-4.jpg","https://img.castlecore.uk/smailholm-tower-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"Floors Castle","county":"Scottish Borders","type":"palace","condition":"intact","era":"18th century","rating":4.4,"reviewCount":2200,"access":"paid","description":"Scotland's largest inhabited castle — a Georgian palace on the banks of the Tweed where border reivers once raided and a king was killed by an exploding cannon.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/Floors_Castle%2C_Roxburghshire.jpg/500px-Floors_Castle%2C_Roxburghshire.jpg","gallery":["https://img.castlecore.uk/floors-castle-2.jpg","https://img.castlecore.uk/floors-castle-3.jpg","https://img.castlecore.uk/floors-castle-4.jpg","https://img.castlecore.uk/floors-castle-5.jpg"],"tags":["well-preserved","photogenic","gardens","riverside","guided-tours","tearoom-cafe","gift-shop"]},{"name":"Thirlestane Castle","county":"Scottish Borders","type":"castle","condition":"intact","era":"16th century","rating":4.2,"reviewCount":780,"access":"paid","description":"One of Scotland's grandest inhabited castles, its fairy-tale turrets and extraordinary Restoration plasterwork ceilings rival any stately home. The Maitland family seat for over 400 years.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b4/Thirlestane_Castle.jpg/500px-Thirlestane_Castle.jpg","gallery":["https://img.castlecore.uk/thirlestane-castle-2.jpg","https://img.castlecore.uk/thirlestane-castle-3.jpg","https://img.castlecore.uk/thirlestane-castle-4.jpg","https://img.castlecore.uk/thirlestane-castle-5.jpg"],"tags":["well-preserved","guided-tours","gardens","kid-friendly","gift-shop","atmospheric"]},{"name":"Fast Castle","county":"Scottish Borders","type":"castle","condition":"ruin","era":"14th-16th century","rating":4.1,"reviewCount":450,"access":"free","description":"A near-impossible clifftop ruin on the Berwickshire coast, accessible only by a vertiginous path. Sir Walter Scott's inspiration for Wolf's Crag in 'The Bride of Lammermoor'.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/de/Fast_Castle_-_geograph.org.uk_-_365002.jpg/500px-Fast_Castle_-_geograph.org.uk_-_365002.jpg","gallery":["https://img.castlecore.uk/fast-castle-2.jpg","https://img.castlecore.uk/fast-castle-3.jpg","https://img.castlecore.uk/fast-castle-4.jpg","https://img.castlecore.uk/fast-castle-5.jpg"],"tags":["ruins-romantic","coastal","cliffside","remote","dark-brooding","atmospheric","free-entry"]},{"name":"Hawick Motte","county":"Scottish Borders","type":"castle","condition":"ruin","era":"12th century","rating":3.4,"reviewCount":70,"access":"free","description":"A great green mound in the heart of Hawick — one of the best-preserved Norman mottes in Scotland. A grassy hillock hiding centuries of Borders warfare beneath its turf.","image":"https://img.castlecore.uk/hawick-motte.jpg","gallery":["https://img.castlecore.uk/hawick-motte-2.jpg","https://img.castlecore.uk/hawick-motte-3.jpg","https://img.castlecore.uk/hawick-motte-4.jpg","https://img.castlecore.uk/hawick-motte-5.jpg"],"tags":["free-entry","norman","medieval"]},{"name":"Cessford Castle","county":"Scottish Borders","type":"castle","condition":"ruin","era":"15th century","rating":3.6,"reviewCount":95,"access":"exterior-only","description":"A massive Border Reiver stronghold with walls thirteen feet thick — where the notorious Kerr clan defied English siege engines and the Earl of Surrey himself.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/Cessford_Castle.jpg/500px-Cessford_Castle.jpg","gallery":["https://img.castlecore.uk/cessford-castle-2.jpg","https://img.castlecore.uk/cessford-castle-3.jpg","https://img.castlecore.uk/cessford-castle-4.jpg","https://img.castlecore.uk/cessford-castle-5.jpg","https://img.castlecore.uk/cessford-castle-main-2.jpg","https://img.castlecore.uk/cessford-castle-main-3.jpg","https://img.castlecore.uk/cessford-castle-main-4.jpg","https://img.castlecore.uk/cessford-castle-main-5.jpg"],"tags":["ruins-romantic","dark-brooding","medieval","atmospheric","remote"]},{"name":"Ferniehirst Castle","county":"Scottish Borders","type":"castle","condition":"intact","era":"15th century","rating":3.8,"reviewCount":220,"access":"paid","description":"The ancestral seat of the Kerr clan, tucked into Jed Water valley near Jedburgh. A fine 16th-century tower house with famously left-handed staircases built for sinister swordsmen.","image":"https://img.castlecore.uk/ferniehirst-castle.jpg","gallery":["https://img.castlecore.uk/ferniehirst-castle-2.jpg","https://img.castlecore.uk/ferniehirst-castle-3.jpg","https://img.castlecore.uk/ferniehirst-castle-4.jpg","https://img.castlecore.uk/ferniehirst-castle-5.jpg"],"tags":["well-preserved","guided-tours","atmospheric","medieval","woodland","riverside"]},{"name":"Greenknowe Tower","county":"Scottish Borders","type":"castle","condition":"ruin","era":"16th century","rating":3.7,"reviewCount":160,"access":"free","description":"A handsome L-plan tower house standing in emerald farmland near Gordon in the Scottish Borders. Remarkably intact, with crow-stepped gables and fine carved details.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Greenknowe_Tower_SW2.jpg/500px-Greenknowe_Tower_SW2.jpg","gallery":["https://img.castlecore.uk/greenknowe-tower-2.jpg","https://img.castlecore.uk/greenknowe-tower-3.jpg","https://img.castlecore.uk/greenknowe-tower-4.jpg","https://img.castlecore.uk/greenknowe-tower-5.jpg"],"tags":["well-preserved","free-entry","atmospheric","ruins-romantic","medieval"]},{"name":"Drochil Castle","county":"Scottish Borders","type":"castle","condition":"ruin","era":"16th century","rating":3.5,"reviewCount":65,"access":"exterior-only","description":"A massive unfinished Elizabethan-era mansion in the Borders, planned as a palace but never completed. Scotland's great architectural 'what if', abandoned when its builder fell from power.","image":"https://img.castlecore.uk/drochil-castle.jpg","gallery":["https://img.castlecore.uk/drochil-castle-2.jpg","https://img.castlecore.uk/drochil-castle-3.jpg","https://img.castlecore.uk/drochil-castle-4.jpg","https://img.castlecore.uk/drochil-castle-5.jpg"],"tags":["ruins-romantic","atmospheric","remote"]},{"name":"Dryhope Tower","county":"Scottish Borders","type":"tower house","condition":"ruin","era":"16th century","rating":3.4,"reviewCount":65,"access":"free","description":"The birthplace of the 'Flower of Yarrow' — a ruined Border pele tower where a beauty married a notorious Reiver and Walter Scott found the threads of his ancestry.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a1/Dryhope.JPG/500px-Dryhope.JPG","gallery":["https://img.castlecore.uk/dryhope-tower-2.jpg","https://img.castlecore.uk/dryhope-tower-3.jpg","https://img.castlecore.uk/dryhope-tower-4.jpg","https://img.castlecore.uk/dryhope-tower-5.jpg","https://img.castlecore.uk/dryhope-tower-main-2.jpg","https://img.castlecore.uk/dryhope-tower-main-3.jpg","https://img.castlecore.uk/dryhope-tower-main-4.jpg","https://img.castlecore.uk/dryhope-tower-main-5.jpg"],"tags":["ruins-romantic","riverside","atmospheric","remote","medieval"]},{"name":"Aikwood Tower","county":"Scottish Borders","type":"tower house","condition":"restored","era":"16th century","rating":3.5,"reviewCount":80,"access":"paid","description":"A 16th-century Border tower restored by a future Liberal leader — where the Ettrick Water winds past centuries of Scott family history and literary legend.","image":"https://img.castlecore.uk/aikwood-tower.jpg","gallery":["https://img.castlecore.uk/aikwood-tower-2.jpg","https://img.castlecore.uk/aikwood-tower-3.jpg","https://img.castlecore.uk/aikwood-tower-4.jpg","https://img.castlecore.uk/aikwood-tower-5.jpg","https://img.castlecore.uk/aikwood-tower-main-2.jpg","https://img.castlecore.uk/aikwood-tower-main-3.jpg","https://img.castlecore.uk/aikwood-tower-main-4.jpg","https://img.castlecore.uk/aikwood-tower-main-5.jpg"],"tags":["well-preserved","medieval","riverside","wedding-venue","atmospheric"]},{"name":"Duns Castle","county":"Scottish Borders","type":"castle","condition":"intact","era":"14th century / 19th century rebuild","rating":3.5,"reviewCount":90,"access":"paid","description":"A baronial mansion set in a 1,200-acre nature reserve in the Borders town of Duns. Gothic Revival grandeur meets outstanding wildlife habitat.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bb/Duns_Castle_-_geograph.org.uk_-_8169370.jpg/500px-Duns_Castle_-_geograph.org.uk_-_8169370.jpg","gallery":["https://img.castlecore.uk/duns-castle-2.jpg","https://img.castlecore.uk/duns-castle-3.jpg","https://img.castlecore.uk/duns-castle-4.jpg","https://img.castlecore.uk/duns-castle-5.jpg"],"tags":["well-preserved","gardens","wedding-venue","events-venue","woodland","gothic"]},{"name":"Cranshaws Castle","county":"Scottish Borders","type":"tower house","condition":"intact","era":"15th century","rating":3.2,"reviewCount":25,"access":"exterior-only","description":"A privately owned 15th-century pele tower still lived in today — hidden in the Berwickshire hills where Oliphants, Douglases, and Swintons held the Borders.","image":"https://img.castlecore.uk/cranshaws-castle.jpg","gallery":["https://img.castlecore.uk/cranshaws-castle-2.jpg","https://img.castlecore.uk/cranshaws-castle-3.jpg","https://img.castlecore.uk/cranshaws-castle-4.jpg","https://img.castlecore.uk/cranshaws-castle-5.jpg","https://img.castlecore.uk/cranshaws-castle-main-2.jpg","https://img.castlecore.uk/cranshaws-castle-main-3.jpg","https://img.castlecore.uk/cranshaws-castle-main-4.jpg","https://img.castlecore.uk/cranshaws-castle-main-5.jpg"],"tags":["well-preserved","medieval","remote","atmospheric"]},{"name":"Fatlips Castle","county":"Scottish Borders","type":"tower house","condition":"restored","era":"16th century","rating":3.5,"reviewCount":30,"access":"free","description":"A restored Border peel tower perched on the summit of Minto Crags, offering sweeping views over the Teviot valley. A perfect little fortress in a perfect Border setting.","image":"https://img.castlecore.uk/fatlips-castle.jpg","gallery":["https://img.castlecore.uk/fatlips-castle-2.jpg","https://img.castlecore.uk/fatlips-castle-3.jpg","https://img.castlecore.uk/fatlips-castle-4.jpg","https://img.castlecore.uk/fatlips-castle-5.jpg"],"tags":["well-preserved","hilltop","atmospheric","woodland","free-entry","photogenic"]},{"name":"Littledean Tower","county":"Scottish Borders","type":"tower house","condition":"ruin","era":"15th century","rating":3.2,"reviewCount":12,"access":"exterior-only","description":"A fine Border peel tower near Maxton, standing amid the gentle rolling landscape of Roxburghshire. A well-preserved example of the Borders' defensive architecture.","image":"https://img.castlecore.uk/littledean-tower.jpg","gallery":["https://img.castlecore.uk/littledean-tower-2.jpg","https://img.castlecore.uk/littledean-tower-3.jpg","https://img.castlecore.uk/littledean-tower-4.jpg","https://img.castlecore.uk/littledean-tower-5.jpg"],"tags":["well-preserved","medieval"]},{"name":"Hume Castle","county":"Scottish Borders","type":"castle","condition":"ruin","era":"13th century / 18th century folly","rating":3.7,"reviewCount":55,"access":"free","description":"A prominent Border hilltop fortress with panoramic views over the Merse, rebuilt as an 18th-century folly on medieval foundations. The Home clan's ancient seat, visible for miles.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/Hume_Castle_-_geograph.org.uk_-_812984.jpg/500px-Hume_Castle_-_geograph.org.uk_-_812984.jpg","gallery":["https://img.castlecore.uk/hume-castle-2.jpg","https://img.castlecore.uk/hume-castle-3.jpg","https://img.castlecore.uk/hume-castle-4.jpg","https://img.castlecore.uk/hume-castle-5.jpg"],"tags":["well-preserved","hilltop","free-entry","photogenic","atmospheric"]},{"name":"Roxburgh Castle","county":"Scottish Borders","type":"castle","condition":"ruin","era":"12th-15th century","rating":3.5,"reviewCount":30,"access":"free","description":"Earthwork remains of one of medieval Scotland's most important royal castles, where James II was killed by an exploding cannon. A pivotal site reduced to grassy mounds.","image":"https://upload.wikimedia.org/wikipedia/commons/0/01/Castles_old_and_new_-_geograph.org.uk_-_163364.jpg","gallery":["https://img.castlecore.uk/roxburgh-castle-2.jpg","https://img.castlecore.uk/roxburgh-castle-3.jpg","https://img.castlecore.uk/roxburgh-castle-4.jpg","https://img.castlecore.uk/roxburgh-castle-5.jpg"],"tags":["ruins-romantic","medieval","free-entry","riverside"]},{"name":"Elibank Castle","county":"Scottish Borders","type":"tower house","condition":"ruin","era":"16th century","rating":3.3,"reviewCount":16,"access":"free","description":"A ruined tower house above the Tweed in a secluded Borders valley, associated with the legend of 'Muckle Mou'd Meg' — a famously ugly bride given as punishment.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/51/Elibank_Castle_-_geograph.org.uk_-_2026524.jpg/500px-Elibank_Castle_-_geograph.org.uk_-_2026524.jpg","gallery":["https://img.castlecore.uk/elibank-castle-2.jpg","https://img.castlecore.uk/elibank-castle-3.jpg","https://img.castlecore.uk/elibank-castle-4.jpg","https://img.castlecore.uk/elibank-castle-5.jpg"],"tags":["ruins-romantic","woodland","riverside","atmospheric","free-entry","remote"]},{"name":"Castle Craig","county":"Scottish Borders","type":"castle","condition":"ruin","era":"Medieval","rating":3.4,"reviewCount":60,"access":"free","description":"A ruined castle on the shores of Loch Ness, one of several fortifications along the Great Glen. Hidden in woodland with atmospheric views across the famous loch.","image":"https://img.castlecore.uk/castle-craig.jpg","gallery":["https://img.castlecore.uk/castle-craig-2.jpg","https://img.castlecore.uk/castle-craig-3.jpg","https://img.castlecore.uk/castle-craig-4.jpg","https://img.castlecore.uk/castle-craig-5.jpg"],"tags":["ruins-romantic","woodland","coastal","free-entry","remote"]},{"name":"Newark Castle (Borders)","county":"Scottish Borders","type":"castle","condition":"ruin","era":"15th century","rating":3.8,"reviewCount":180,"access":"free","description":"A ruined tower house in the Yarrow Valley, scene of a terrible massacre of prisoners after the Battle of Philiphaugh. Walter Scott's inspiration for 'The Lay of the Last Minstrel'.","image":"https://img.castlecore.uk/newark-castle-borders.jpg","gallery":["https://img.castlecore.uk/newark-castle-borders-2.jpg","https://img.castlecore.uk/newark-castle-borders-3.jpg","https://img.castlecore.uk/newark-castle-borders-4.jpg","https://img.castlecore.uk/newark-castle-borders-5.jpg"],"tags":["ruins-romantic","atmospheric","dark-brooding","free-entry","riverside"]},{"name":"Abbotsford House","county":"Scottish Borders","type":"castle","condition":"intact","era":"19th century","rating":4.5,"reviewCount":2800,"access":"paid","description":"Sir Walter Scott's dream made stone — a Scottish baronial fantasy on the banks of the Tweed, stuffed with relics and the inspiration for a literary revolution.","image":"https://img.castlecore.uk/abbotsford-house.jpg","gallery":["https://img.castlecore.uk/abbotsford-house-2.jpg","https://img.castlecore.uk/abbotsford-house-3.jpg","https://img.castlecore.uk/abbotsford-house-4.jpg","https://img.castlecore.uk/abbotsford-house-5.jpg"],"tags":["well-preserved","photogenic","atmospheric","riverside","museum","gardens","guided-tours","gift-shop"]},{"name":"Traquair House","county":"Scottish Borders","type":"castle","condition":"intact","era":"12th century onwards","rating":4.4,"reviewCount":2200,"access":"paid","description":"Scotland's oldest continuously inhabited house — a romantic white-harled mansion in the Tweed valley that has sheltered 27 Scottish monarchs and hidden Catholic priests.","image":"https://img.castlecore.uk/wiki-traquair-house.jpg","tags":["well-preserved","guided-tours","gardens","gift-shop","tearoom-cafe","kid-friendly","atmospheric","dog-friendly"]},{"name":"Peebles Cross Kirk","county":"Sco