[{"name":"Caerlaverock Castle","county":"Dumfries and Galloway","type":"castle","condition":"ruin","era":"13th century","rating":4.5,"reviewCount":3200,"access":"paid","description":"Scotland's only triangular castle, Caerlaverock's unique shape and twin-towered gatehouse make it unmistakable. It was besieged by Edward I in 1300 with an army of 87 knights.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8b/Caerlaverock_Castle_from_the_air.jpg/500px-Caerlaverock_Castle_from_the_air.jpg","gallery":["https://img.castlecore.uk/caerlaverock-castle-2.jpg","https://img.castlecore.uk/caerlaverock-castle-3.jpg","https://img.castlecore.uk/caerlaverock-castle-4.jpg","https://img.castlecore.uk/caerlaverock-castle-5.jpg","https://img.castlecore.uk/caerlaverock-castle-interior-2.jpg","https://img.castlecore.uk/caerlaverock-castle-interior-3.jpg","https://img.castlecore.uk/caerlaverock-castle-interior-4.jpg","https://img.castlecore.uk/caerlaverock-castle-interior-5.jpg"],"tags":["dramatic-ruin","photogenic","kid-friendly"]},{"name":"Threave Castle","county":"Dumfries and Galloway","type":"tower house","condition":"ruin","era":"14th century","rating":4.2,"reviewCount":1560,"access":"paid","description":"Built by Archibald the Grim, Lord of Galloway, Threave's massive tower stands on an island in the River Dee. The artillery wall was added to resist the growing power of cannons.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d1/Threave_Castle_20080422_-_view_from_Dee.jpg/500px-Threave_Castle_20080422_-_view_from_Dee.jpg","gallery":["https://img.castlecore.uk/threave-castle-2.jpg","https://img.castlecore.uk/threave-castle-3.jpg","https://img.castlecore.uk/threave-castle-4.jpg","https://img.castlecore.uk/threave-castle-5.jpg","https://img.castlecore.uk/threave-castle-interior-2.jpg","https://img.castlecore.uk/threave-castle-interior-3.jpg","https://img.castlecore.uk/threave-castle-interior-4.jpg","https://img.castlecore.uk/threave-castle-interior-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"MacLellan's Castle","county":"Dumfries and Galloway","type":"tower house","condition":"ruin","era":"16th century","rating":4,"reviewCount":890,"access":"paid","description":"An elaborate town house built from the stones of a Franciscan friary by Sir Thomas MacLellan. The laird's lug (spy-hole) allowed eavesdropping from the master bedroom.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/Sweetheart_Abbey.jpg/500px-Sweetheart_Abbey.jpg","gallery":["https://img.castlecore.uk/maclellan-s-castle-2.jpg","https://img.castlecore.uk/maclellan-s-castle-3.jpg","https://img.castlecore.uk/maclellan-s-castle-4.jpg","https://img.castlecore.uk/maclellan-s-castle-5.jpg"],"tags":["dramatic-ruin","hidden-gem"]},{"name":"Sweetheart Abbey","county":"Dumfries and Galloway","type":"abbey","condition":"ruin","era":"13th century","rating":4.3,"reviewCount":1670,"access":"paid","description":"Founded by Lady Devorgilla in memory of her husband John Balliol, she carried his embalmed heart with her until death. The rosy sandstone ruins and precinct wall are remarkably complete.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/Sweetheart_Abbey.jpg/500px-Sweetheart_Abbey.jpg","gallery":["https://img.castlecore.uk/sweetheart-abbey-2.jpg","https://img.castlecore.uk/sweetheart-abbey-3.jpg","https://img.castlecore.uk/sweetheart-abbey-4.jpg","https://img.castlecore.uk/sweetheart-abbey-5.jpg","https://img.castlecore.uk/sweetheart-abbey-ruins-2.jpg","https://img.castlecore.uk/sweetheart-abbey-ruins-3.jpg","https://img.castlecore.uk/sweetheart-abbey-ruins-4.jpg","https://img.castlecore.uk/sweetheart-abbey-ruins-5.jpg"],"tags":["romantic-ruin","photogenic","hidden-gem"]},{"name":"Dean Castle","county":"East Ayrshire","type":"castle","condition":"intact","era":"14th century","rating":4,"reviewCount":1340,"access":"free","description":"A restored medieval castle in Kilmarnock consisting of a keep and palace, home to the Boyd family. It houses collections of arms, armour, and early musical instruments.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6c/Dean_Castle%2C_East_Ayrshire_%28cropped%29.jpg/500px-Dean_Castle%2C_East_Ayrshire_%28cropped%29.jpg","gallery":["https://img.castlecore.uk/dean-castle-2.jpg","https://img.castlecore.uk/dean-castle-3.jpg","https://img.castlecore.uk/dean-castle-4.jpg","https://img.castlecore.uk/dean-castle-5.jpg","https://img.castlecore.uk/dean-castle-main-2.jpg","https://img.castlecore.uk/dean-castle-main-3.jpg","https://img.castlecore.uk/dean-castle-main-4.jpg","https://img.castlecore.uk/dean-castle-main-5.jpg"],"tags":["well-preserved","kid-friendly","hidden-gem"]},{"name":"Culzean Castle","county":"South Ayrshire","type":"castle","condition":"intact","era":"18th century","rating":4.5,"reviewCount":3890,"access":"paid","description":"Robert Adam's masterpiece perched on the Ayrshire cliffs, Culzean is Scotland's most popular National Trust property. General Eisenhower was given a flat here after WWII.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/99/Culzean_Castle_house_and_gardens_01.JPG/500px-Culzean_Castle_house_and_gardens_01.JPG","gallery":["https://img.castlecore.uk/culzean-castle-2.jpg","https://img.castlecore.uk/culzean-castle-3.jpg","https://img.castlecore.uk/culzean-castle-4.jpg","https://img.castlecore.uk/culzean-castle-5.jpg"],"tags":["well-preserved","photogenic","kid-friendly"]},{"name":"Lochranza Castle","county":"North Ayrshire","type":"castle","condition":"ruin","era":"14th century","rating":4.1,"reviewCount":1120,"access":"free","description":"A picturesque ruin on a spit of land on the Isle of Arran, Lochranza may be where Robert the Bruce returned from Ireland in 1306. Red deer often graze around its walls.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/Lochranza_Castle_1.jpg/500px-Lochranza_Castle_1.jpg","gallery":["https://img.castlecore.uk/lochranza-castle-2.jpg","https://img.castlecore.uk/lochranza-castle-3.jpg","https://img.castlecore.uk/lochranza-castle-4.jpg","https://img.castlecore.uk/lochranza-castle-5.jpg","https://img.castlecore.uk/lochranza-castle-main-2.jpg","https://img.castlecore.uk/lochranza-castle-main-3.jpg","https://img.castlecore.uk/lochranza-castle-main-4.jpg","https://img.castlecore.uk/lochranza-castle-main-5.jpg"],"tags":["romantic-ruin","photogenic","hidden-gem","free"]},{"name":"Brodick Castle","county":"North Ayrshire","type":"castle","condition":"intact","era":"16th century","rating":4.3,"reviewCount":2120,"access":"paid","description":"The ancestral home of the Dukes of Hamilton on the Isle of Arran, Brodick commands views of Goat Fell. Its woodland gardens contain one of Europe's finest rhododendron collections.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Brodick_Castle_Main_Building_East_01.jpg/500px-Brodick_Castle_Main_Building_East_01.jpg","gallery":["https://img.castlecore.uk/brodick-castle-2.jpg","https://img.castlecore.uk/brodick-castle-3.jpg","https://img.castlecore.uk/brodick-castle-4.jpg","https://img.castlecore.uk/brodick-castle-5.jpg","https://img.castlecore.uk/brodick-castle-main-2.jpg","https://img.castlecore.uk/brodick-castle-main-3.jpg","https://img.castlecore.uk/brodick-castle-main-4.jpg","https://img.castlecore.uk/brodick-castle-main-5.jpg"],"tags":["well-preserved","photogenic","hidden-gem"]},{"name":"Dundrennan Abbey","county":"Dumfries and Galloway","type":"abbey","condition":"ruin","era":"12th century","rating":4.2,"reviewCount":680,"access":"paid","description":"Where Mary Queen of Scots spent her last night in Scotland before crossing the Solway Firth into captivity — austere Cistercian beauty in grey sandstone that has weathered 900 years.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7b/Dundrennan_Abbey_2012_%281%29.jpg/500px-Dundrennan_Abbey_2012_%281%29.jpg","gallery":["https://img.castlecore.uk/dundrennan-abbey-2.jpg","