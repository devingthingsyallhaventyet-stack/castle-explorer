[{"name":"Castle Campbell","county":"Clackmannanshire","type":"castle","condition":"partial ruin","era":"15th century","rating":3.9,"reviewCount":92,"access":"paid","description":"Dramatically situated at the head of Dollar Glen between two ravines, Castle Campbell was the lowland seat of the Campbell Earls of Argyll. The tower house and loggia survive.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/Castle_Campbell_%28July_2007%29.jpg/500px-Castle_Campbell_%28July_2007%29.jpg","gallery":["https://img.castlecore.uk/castle-campbell-2.jpg","https://img.castlecore.uk/castle-campbell-3.jpg","https://img.castlecore.uk/castle-campbell-4.jpg","https://img.castlecore.uk/castle-campbell-5.jpg","https://img.castlecore.uk/castle-campbell-main-2.jpg","https://img.castlecore.uk/castle-campbell-main-3.jpg","https://img.castlecore.uk/castle-campbell-main-4.jpg","https://img.castlecore.uk/castle-campbell-main-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"Alloa Tower","county":"Clackmannanshire","type":"tower house","condition":"intact","era":"14th century","rating":4,"reviewCount":890,"access":"paid","description":"The largest surviving medieval tower house in Scotland, Alloa was the ancestral home of the Earls of Mar. Its Italian Renaissance painted ceilings are nationally important.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/61/Alloa_Tower_%28September_2020%29.jpg/500px-Alloa_Tower_%28September_2020%29.jpg","gallery":["https://img.castlecore.uk/alloa-tower-2.jpg","https://img.castlecore.uk/alloa-tower-3.jpg","https://img.castlecore.uk/alloa-tower-4.jpg","https://img.castlecore.uk/alloa-tower-5.jpg"],"tags":["well-preserved","hidden-gem"]},{"name":"St Andrews Castle","county":"Fife","type":"castle","condition":"ruin","era":"13th century","rating":4.2,"reviewCount":2560,"access":"paid","description":"The dramatic ruins of the bishop's castle overlook St Andrews Bay. Its famous bottle dungeon and siege mine and counter-mine tunnels are unique survivals.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/17/St_Andrews_Castle_1_%283604221101%29.jpg/500px-St_Andrews_Castle_1_%283604221101%29.jpg","gallery":["https://img.castlecore.uk/st-andrews-castle-2.jpg","https://img.castlecore.uk/st-andrews-castle-3.jpg","https://img.castlecore.uk/st-andrews-castle-4.jpg","https://img.castlecore.uk/st-andrews-castle-5.jpg"],"tags":["dramatic-ruin","photogenic","hidden-gem"]},{"name":"Huntingtower Castle","county":"Perth and Kinross","type":"castle","condition":"partial ruin","era":"15th century","rating":4.1,"reviewCount":1120,"access":"paid","description":"Two complete medieval tower houses standing side by side, later joined together. It contains the finest surviving medieval painted ceiling in Scotland.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Perth_and_Kinross_Huntingtower_Castle.jpg/500px-Perth_and_Kinross_Huntingtower_Castle.jpg","gallery":["https://img.castlecore.uk/huntingtower-castle-2.jpg","https://img.castlecore.uk/huntingtower-castle-3.jpg","https://img.castlecore.uk/huntingtower-castle-4.jpg","https://img.castlecore.uk/huntingtower-castle-5.jpg","https://img.castlecore.uk/huntingtower-castle-keep-2.jpg","https://img.castlecore.uk/huntingtower-castle-keep-3.jpg","https://img.castlecore.uk/huntingtower-castle-keep-4.jpg","https://img.castlecore.uk/huntingtower-castle-keep-5.jpg"],"tags":["well-preserved","hidden-gem"]},{"name":"Elcho Castle","county":"Perth and Kinross","type":"tower house","condition":"partial ruin","era":"16th century","rating":4.1,"reviewCount":780,"access":"paid","description":"A remarkably complete 16th-century fortified mansion on the banks of the Tay. Its projecting towers, wrought-iron grilles, and original timber floors are exceptionally well preserved.","image":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/50/Elcho_castle.jpg/500px-Elcho_castle.jpg","gallery":["https://img.castlecore.uk/elcho-castle-2.jpg",